<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customer Invoice: RUG account-update button + status fields -->
    <record id="account_move_form_rug" model="ir.ui.view">
        <field name="name">account.move.form.rug</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- "Update RUG Account" button in header -->
            <xpath expr="//button[@name='action_post']" position="before">
                <button name="action_update_rug_account"
                        type="object"
                        string="Update RUG Account"
                        class="btn-primary"
                        attrs="{'invisible': ['|', '|',
                            ('x_studio_rug_confirmed', '=', False),
                            ('x_studio_rug_acc_updated', '=', True),
                            '&amp;',
                            ('x_studio_rug_confirmed', '=', True),
                            ('x_studio_rug_rejected', '=', True)]}"/>
            </xpath>
            <!-- Hidden RUG state fields (force_save so they stay synced) -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_studio_rug_confirmed" invisible="1" force_save="1"/>
                <field name="x_studio_rug_rejected" invisible="1" force_save="1"/>
                <field name="x_studio_rug_acc_updated"
                       string="RUG Account Updated"
                       readonly="1"
                       force_save="1"
                       invisible="1"/>
            </xpath>
            <!-- Block "Register Payment" on RUG invoices until account is updated -->
            <xpath expr="//button[@name='action_register_payment']" position="attributes">
                <attribute name="attrs">{'invisible': ['|', '|', '|', '|',
                    ('state', '!=', 'posted'),
                    ('payment_state', 'not in', ('not_paid', 'partial')),
                    ('move_type', 'not in', ('out_invoice', 'out_refund',
                        'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')),
                    '&amp;',
                    ('x_studio_rug_confirmed', '=', True),
                    ('x_studio_rug_acc_updated', '=', False)]}</attribute>
            </xpath>
        </field>
    </record>

</odoo>
