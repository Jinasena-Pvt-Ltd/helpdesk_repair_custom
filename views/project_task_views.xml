<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_form_dispatch" model="ir.ui.view">
        <field name="name">project.task.form.dispatch</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="timesheet_grid.project_task_view_form"/>
        <field name="arch" type="xml">
            <!--
                Add the Dispatch button after the Mark as Done buttons.
                Visible only when:
                  - task is marked done (fsm_done = True)
                  - dispatch has not already been created (x_studio_dispatch_done = False)
            -->
            <xpath expr="//button[@name='action_fsm_validate'][hasclass('btn-secondary')]" position="after">
                <field name="x_studio_dispatch_done" invisible="1"/>
                <field name="x_studio_fully_invoiced_so" invisible="1"/>
                <button class="btn-primary" name="action_dispatch" type="object"
                        string="Dispatch"
                        attrs="{'invisible': ['|', ('fsm_done', '=', False), ('x_studio_dispatch_done', '=', True)]}"/>
            </xpath>
        </field>
    </record>
</odoo>
